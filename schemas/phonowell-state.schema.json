{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phonowell.dev/schemas/phonowell-state.schema.json",
  "title": "Phonowell Project State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "well",
    "drops",
    "relations",
    "domainNodes",
    "domainEdges",
    "candidates",
    "proposals",
    "verifyReports",
    "verifyCycles",
    "selfIterationRecords",
    "packetRecords",
    "pendingChangedDropIds",
    "runLogs",
    "unresolvedQuestions",
    "assetConversations",
    "automationTasks",
    "activityTimeline",
    "generationHistory",
    "assistantLoop"
  ],
  "properties": {
    "project": {
      "type": "object",
      "required": ["projectId", "name", "slug", "workdir", "createdAt", "updatedAt"],
      "properties": {
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "workdir": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "well": {
      "type": "object",
      "required": [
        "id",
        "artifactType",
        "wish",
        "definitionOfDone",
        "constraints",
        "acceptanceDropId",
        "acceptanceStatus",
        "status",
        "dryRunStatus",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string" },
        "artifactType": { "type": "string" },
        "wish": { "type": "string" },
        "definitionOfDone": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "originDropId": { "type": "string" },
        "acceptanceDropId": { "type": "string" },
        "acceptanceStatus": { "type": "string", "enum": ["pending", "accepted"] },
        "acceptedCandidateId": { "type": "string" },
        "acceptedAt": { "type": "string" },
        "status": { "type": "string" },
        "dryRunStatus": { "type": "string", "enum": ["pass", "warn", "fail"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "schemaVersion": { "type": "string", "enum": ["1.0.0", "1.1.0"] },
    "drops": { "type": "array", "items": { "$ref": "https://phonowell.dev/schemas/drop.schema.json" } },
    "relations": { "type": "array", "items": { "$ref": "https://phonowell.dev/schemas/relation.schema.json" } },
    "domainNodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domainId", "wellId", "name", "summary", "kind", "status", "frozen", "assetDropIds", "position", "createdAt", "updatedAt"],
        "properties": {
          "domainId": { "type": "string" },
          "wellId": { "type": "string" },
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "kind": { "type": "string", "enum": ["system", "workspace", "inbox"] },
          "status": { "type": "string", "enum": ["stable", "new", "absorbing", "attention", "frozen"] },
          "frozen": { "type": "boolean" },
          "assetDropIds": { "type": "array", "items": { "type": "string" } },
          "position": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" },
          "lastActivityAt": { "type": "string" }
        }
      }
    },
    "domainEdges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["edgeId", "wellId", "fromDomainId", "toDomainId", "kind", "summary", "createdAt", "updatedAt"],
        "properties": {
          "edgeId": { "type": "string" },
          "wellId": { "type": "string" },
          "fromDomainId": { "type": "string" },
          "toDomainId": { "type": "string" },
          "kind": { "type": "string", "enum": ["structure", "causal", "supports"] },
          "summary": { "type": "string" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        }
      }
    },
    "candidates": { "type": "array", "items": { "$ref": "https://phonowell.dev/schemas/candidate.schema.json" } },
    "proposals": { "type": "array", "items": { "type": "object" } },
    "verifyReports": { "type": "array", "items": { "$ref": "https://phonowell.dev/schemas/verify-report.schema.json" } },
    "verifyCycles": { "type": "array", "items": { "type": "object" } },
    "selfIterationRecords": { "type": "array", "items": { "type": "object" } },
    "packetRecords": { "type": "array", "items": { "$ref": "https://phonowell.dev/schemas/packet-record.schema.json" } },
    "pendingChangedDropIds": { "type": "array", "items": { "type": "string" } },
    "runLogs": { "type": "array", "items": { "type": "object" } },
    "unresolvedQuestions": { "type": "array", "items": { "type": "string" } },
    "assetConversations": { "type": "array", "items": { "type": "object" } },
    "automationTasks": { "type": "array", "items": { "type": "object" } },
    "activityTimeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["activityId", "actor", "kind", "summary", "relatedDomainIds", "relatedDropIds", "createdAt"],
        "properties": {
          "activityId": { "type": "string" },
          "actor": { "type": "string", "enum": ["ai", "user", "system"] },
          "kind": { "type": "string" },
          "summary": { "type": "string" },
          "detail": { "type": "string" },
          "relatedDomainIds": { "type": "array", "items": { "type": "string" } },
          "relatedDropIds": { "type": "array", "items": { "type": "string" } },
          "createdAt": { "type": "string" },
          "undoSummary": { "type": "string" }
        }
      }
    },
    "generationHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recordId", "snapshot", "diff", "createdAt"],
        "properties": {
          "recordId": { "type": "string" },
          "candidateId": { "type": "string" },
          "snapshot": { "type": "object" },
          "diff": { "type": "object" },
          "createdAt": { "type": "string" }
        }
      }
    },
    "assistantLoop": {
      "type": "object",
      "required": ["status", "userState", "statusLabel", "summary", "nextAction", "updatedAt"],
      "properties": {
        "status": { "type": "string", "enum": ["idle", "running", "blocked", "complete", "failed"] },
        "userState": { "type": "string", "enum": ["ready", "needs-input", "risk-found", "evidence-attached"] },
        "statusLabel": { "type": "string" },
        "summary": { "type": "string" },
        "blockedReason": { "type": "string" },
        "nextAction": {
          "type": "object",
          "required": ["key", "label", "detail"],
          "properties": {
            "key": { "type": "string" },
            "label": { "type": "string" },
            "detail": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string" },
        "lastRunAt": { "type": "string" },
        "latestCandidateId": { "type": "string" },
        "latestVerifyPass": { "type": "boolean" },
        "lastError": { "type": "string" }
      }
    }
  }
}
