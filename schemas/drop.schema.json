{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phonowell.dev/schemas/drop.schema.json",
  "title": "Phonowell Drop",
  "type": "object",
  "required": [
    "dropId",
    "wellId",
    "type",
    "domain",
    "scope",
    "source",
    "owner",
    "layer",
    "title",
    "summary",
    "priority",
    "confidence",
    "licenseState",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "dropId": { "type": "string" },
    "wellId": { "type": "string" },
    "type": { "type": "string" },
    "domain": { "type": "string" },
    "scope": { "type": "string" },
    "source": { "type": "string" },
    "owner": { "type": "string" },
    "layer": { "type": "string", "enum": ["contract", "policy", "reference"] },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "purpose": { "type": "string" },
    "content": { "type": "string" },
    "sourceFile": { "type": "string" },
    "priority": { "type": "string" },
    "confidence": { "type": "number" },
    "licenseState": { "type": "string" },
    "lifecycleState": { "type": "string" },
    "parentDropId": { "type": "string" },
    "goalStatus": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  }
}
